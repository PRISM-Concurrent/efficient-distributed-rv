@startuml systemArquitecture
  top to bottom direction
  allow_mixing

  package "System Arquitecture" {

    ' =========================
    ' Core API
    ' =========================
    interface DistAlgorithm {
        + List<MethodInf> methods()
        + Object apply(Method method, Object... args)
    }

    class A {
        - List<MethodInf> methodList
        - Object instance
        + A(String className)
        + A(String className, String... methodNames)
        + List<MethodInf> methods()
        + Object apply(Method method, Object... args)
    }

    class MethodInf {
        - Method method
        - String name
        - List<Type> typeParam
        - Type typeReturn
        + MethodInf(Method method)
        + Method getMethod()
        + String getName()
        + List<Type> getTypeParam()
        + Type getTypeReturn()
    }

    class OperationCall {
        - Object args
        - MethodInf method
        + OperationCall(Object args, MethodInf method)
        + Object args()
        + String argsAsString()
        + MethodInf method()
        + String toString()
    }

    ' =========================
    ' Snapshot layer
    ' =========================
    abstract class Snapshot {
        + void write(int id, Object invocation)
        + void snapshot(int id, Object response)
        + IPersistentVector buildXE()
    }

    class CollectFAInc {
        - AtomicInteger atomicCounter
        - List<IPersistentVector> threadLogs
        + CollectFAInc(int numThreads)
        + void write(int id, Object invocation)
        + void snapshot(int id, Object response)
        + IPersistentVector buildXE()
    }

    class CollectRAW {
        - List<IPersistentVector> invLogs
        - List<IPersistentVector> resLogs
        + CollectRAW(int numThreads)
        + void write(int id, Object invocation)
        + void snapshot(int id, Object response)
        + IPersistentVector buildXE()
    }

    ' =========================
    ' Runtime layer
    ' =========================
    class Wrapper {
        - Snapshot c
        - DistAlgorithm alg
        + Wrapper(DistAlgorithm alg, Snapshot snapshot)
        + void execute(int processId, OperationCall call)
    }

    class Verifier {
        - Snapshot c
        + Verifier(Snapshot snapshot)
        + boolean checkLinearizabilityJitLin(String objectType)
    }

    class Executioner {
        + int processes
        + int totalOps
        - String objectType
        - Snapshot c
        - DistAlgorithm A
        - Verifier verifier
        - Wrapper wrapper
        - long verifierNanos
        + Executioner(int processes, int totalOps,
                      DistAlgorithm A, String objectType,
                      String snapType)
        + void taskProducers()
        + void taskProducersSeed(List<OperationCall> ops)
        + boolean taskVerifiers()
    }

    class JitLinChecker {
        '- static IFn linFn
        '- static IFn keywordFn
        + static boolean checkLinearizable(IPersistentVector xe,
                                           Logger logger,
                                           String objectType)
    }


    ' =========================
    ' Relationships
    ' =========================
    A ..|> DistAlgorithm

    DistAlgorithm --> MethodInf : uses
    OperationCall --> MethodInf : has

    Snapshot <|-- CollectFAInc
    Snapshot <|-- CollectRAW

    Wrapper --> Snapshot
    Wrapper --> DistAlgorithm
    Wrapper --> OperationCall : execute(...)

    Verifier --> Snapshot
    Verifier ..> JitLinChecker : uses

    Executioner --> Snapshot
    Executioner --> DistAlgorithm
    Executioner --> Wrapper
    Executioner --> Verifier
    Executioner ..> OperationCall 

    Snapshot ..> OperationCall : stores/casts

  }
@enduml